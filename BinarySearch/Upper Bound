/*
 * Upper Bound
 *
 * Problem:
 * Find the first index where the value is strictly greater than the target.
 *
 * Approach:
 * - Use Binary Search.
 * - If arr[mid] > target, store the answer and move left.
 * - Otherwise, move right.
 *
 * Time Complexity: O(log n)
 * Space Complexity: O(1)
 *
 * Topic: Binary Search
 */
class Solution {
    public int upperBound(int[] nums, int x) {
      int low=0,high=nums.length-1;
      while(low<=high)
      {
        int mid=low+(high-low)/2;
        if(nums[mid]>x)
           high=mid-1;
        else
        low=mid+1;
      }
      return low;
    }
}
